{
  "name": "@repo/shared",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "bullmq": "^5.79.1",
    "dotenv": "^17.4.2",
    "ioredis": "5.10.1",
    "zod": "^4.4.3",
    "tsup": "^8.5.1"
  }
}
