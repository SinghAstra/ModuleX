{
  "name": "@repo/db",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "build": "prisma generate && tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "tsup": "^8.5.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prisma": "6"
  }
}
